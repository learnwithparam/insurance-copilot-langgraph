# ============================================================================
# LLM Provider Configuration (at least ONE required)
# ============================================================================

# Set provider: "openrouter", "fireworks", "gemini", "openai"
LLM_PROVIDER=openrouter

# OpenRouter (recommended - access to many models, has free tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-12b-it

# FireworksAI
# FIREWORKS_API_KEY=your_fireworks_api_key_here
# FIREWORKS_MODEL=accounts/fireworks/models/qwen3-235b-a22b-instruct-2507

# Google Gemini (free tier)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Embedding / RAG Configuration
# ============================================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PATH=chroma_db
CHROMA_COLLECTION=insurance_policies

# ============================================================================
# Database
# ============================================================================
INSURANCE_DB_PATH=insurance.db

# ============================================================================
# Server Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
